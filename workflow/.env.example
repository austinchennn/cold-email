# ─── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ─── Optional: model override ─────────────────────────────────────────────────
# Default: gpt-4o  (gpt-4o-mini works too, cheaper but lower quality)
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# ─── Optional: Tavily Search API (higher-quality web search) ──────────────────
# Free tier available at https://tavily.com
# If left blank, DuckDuckGo search is used as a fallback.
TAVILY_API_KEY=

# ─── Optional: behaviour tuning ───────────────────────────────────────────────
MAX_PROFESSORS=10    # How many professors Agent1 should discover
TOP_K_PROJECTS=3     # How many projects Agent3 matches per professor
# ─── Agent 5: Gmail Send ────────────────────────────────────────────────────────────────────
#
# SETUP (one-time):
#   1. Google Cloud Console → APIs & Services → Enable Gmail API
#   2. Credentials → Create OAuth 2.0 Client (Desktop App)
#   3. Download JSON → save as config/gmail_credentials.json
#   4. First run opens a browser tab; approve once → token auto-saved
#
# false = dry-run (default): generate files, do NOT actually send emails
# true  = live mode:          actually send via Gmail API
GMAIL_ENABLED=false

# Paths (relative to project root)
GMAIL_CREDENTIALS_PATH=config/gmail_credentials.json
GMAIL_TOKEN_PATH=config/gmail_token.json

# Anti-spam: max emails per calendar day (Gmail free ≤500; workspace ≤2000)
GMAIL_DAILY_LIMIT=50

# Random sleep between successive sends (seconds)
GMAIL_DELAY_MIN=60
GMAIL_DELAY_MAX=120

# Days before sending follow-up if no reply (0 = never follow up)
GMAIL_FOLLOW_UP_DAYS=3